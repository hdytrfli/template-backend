# environtment
NODE_ENV=development
LOG_LEVEL=debug

# application
PORT=3000
BIND=0.0.0.0
ORIGIN=http://localhost:5173
APPLICATION=template-testing

# database
MONGODB_URI=mongodb://root:example@127.0.0.1:27017/template-testing?authSource=admin

# rabbitmq
RABBITMQ_URI=amqp://admin:password@127.0.0.1:5672

# cookie
COOKIE_SECRET=change-me-to-a-random-secret-min-16-chars
COOKIE_DOMAIN=localhost

# jwt
JWT_ACCESS_SECRET=change-me-to-a-long-random-secret-key
JWT_REFRESH_SECRET=change-me-to-another-long-random-secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
JWT_ACCESS_TOKEN_NAME=access-token
JWT_REFRESH_TOKEN_NAME=refresh-token